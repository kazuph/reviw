{
  "name": "reviw",
  "version": "1.0.0",
  "description": "Lightweight file reviewer with in-browser comments for CSV, TSV, Markdown, and Git diffs.",
  "type": "module",
  "bin": {
    "reviw": "./cli.cjs"
  },
  "files": [
    "cli.cjs"
  ],
  "scripts": {
    "test": "npm run test:v2",
    "test:v1": "vitest run",
    "test:v2": "cd v2 && moon test --target js && moon build --target js --release && node e2e/smoke.mjs && node e2e/media_sidebar_regression.mjs",
    "test:all": "npm run test:v2 && vitest run",
    "test:watch": "vitest",
    "build": "cd v2 && moon build --target js --release"
  },
  "license": "MIT",
  "author": "kazuph",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chardet": "^2.0.0",
    "iconv-lite": "^0.6.3",
    "js-yaml": "^4.1.0",
    "marked": "^12.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "playwright": "^1.57.0",
    "vitest": "^4.0.14"
  }
}
